# Server
PORT=3000
# Must exactly match the URL configured in Square Developer Console, including path.
PUBLIC_WEBHOOK_URL=https://your-domain.com/square-webhook

# Square
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=YOUR_SQUARE_PRODUCTION_ACCESS_TOKEN
SQUARE_SIGNATURE_KEY=YOUR_SQUARE_WEBHOOK_SIGNATURE_KEY
SQUARE_API_VERSION=2026-05-20

# Watched category: use CATEGORY_ID if you know it. Otherwise CATEGORY_NAME will be resolved.
CATEGORY_ID=
CATEGORY_NAME=TCG Singles

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional: mention a Discord role when an item is added/sold/quantity changes. Use the numeric role ID only.
ROLE_MENTION_ID=

# Optional Discord display settings
SHOW_ITEM_IMAGE=true

# Link behavior.
# Square direct item links are only available when Square returns item_data.ecom_uri, which is deprecated and often missing.
# Recommended: direct_only, so the bot does not post broken fallback/search links.
# Options: direct_only, none, fallback, search, template
LINK_MODE=direct_only
STORE_SEARCH_URL=
STORE_FALLBACK_URL=
STORE_ITEM_URL_TEMPLATE=

# Behavior
ANNOUNCE_ADDS=true
# Existing catalog edits such as price/name/image changes are ignored by default.
ANNOUNCE_CATALOG_UPDATES=false
# Legacy compatibility only. Prefer ANNOUNCE_CATALOG_UPDATES.
ANNOUNCE_UPDATES=false
# Quantity changes require subscribing to inventory.count.updated in Square.
ANNOUNCE_QUANTITY_UPDATES=true
ANNOUNCE_SOLD_OUT=true
INVENTORY_STATE=IN_STOCK
ONLY_ANNOUNCE_ACTIVE_ITEMS=true
SYNC_LOOKBACK_SECONDS=5

# Render/persistence
# For a paid Render service with a persistent disk mounted at /var/data, use /var/data.
# For local development, leave this as data.
STATE_DIR=data

# Optional admin token for protected endpoints /admin/seed and /admin/test-discord.
# Make this a long random value.
ADMIN_TOKEN=change_this_long_random_value
