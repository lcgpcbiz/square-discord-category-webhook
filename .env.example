# Server
PORT=3000
# Must exactly match the URL configured in Square Developer Console, including path.
PUBLIC_WEBHOOK_URL=https://your-domain.com/square-webhook

# Square
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=YOUR_SQUARE_PRODUCTION_ACCESS_TOKEN
SQUARE_SIGNATURE_KEY=YOUR_SQUARE_WEBHOOK_SIGNATURE_KEY
SQUARE_API_VERSION=2026-05-20

# Watched category: use CATEGORY_ID if you know it. Otherwise CATEGORY_NAME will be resolved.
CATEGORY_ID=
CATEGORY_NAME=Singles

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional: mention a Discord role when an item is added/updated. Use the numeric role ID only.
ROLE_MENTION_ID=

# Optional Discord display settings
SHOW_ITEM_IMAGE=true
# If Square does not return item_data.ecom_uri, link to a search page or store page instead.
# STORE_SEARCH_URL=https://lctcg.com/s/search
# STORE_FALLBACK_URL=https://lctcg.com/s/shop
STORE_SEARCH_URL=
STORE_FALLBACK_URL=

# Behavior
ANNOUNCE_ADDS=true
ANNOUNCE_UPDATES=true
ONLY_ANNOUNCE_ACTIVE_ITEMS=true
SYNC_LOOKBACK_SECONDS=5

# Render/persistence
# For a paid Render service with a persistent disk mounted at /var/data, use /var/data.
# For local development, leave this as data.
STATE_DIR=data

# Optional admin token for protected endpoints /admin/seed and /admin/test-discord.
# Make this a long random value.
ADMIN_TOKEN=change_this_long_random_value
